{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://promptscout.com/schemas/ai-visibility-audit/remediation-plan.schema.json",
  "title": "AI Visibility Audit Remediation Plan",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "planVersion",
    "site",
    "generatedAt",
    "summary",
    "actionBuckets"
  ],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "planVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "site": {
      "type": "string",
      "format": "uri"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "priority",
        "bucketCount"
      ],
      "properties": {
        "priority": {
          "enum": [
            "healthy",
            "needs-work"
          ]
        },
        "bucketCount": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "actionBuckets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/actionBucket"
      }
    },
    "optionalFollowUps": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "actionBucket": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "title",
        "category",
        "priority",
        "fixType",
        "whyItMatters",
        "smallestChangeSet",
        "affectedEvidence"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "enum": [
            "crawl-access-blockers",
            "diagnosis-groups",
            "template-fixes",
            "core-page-upgrades",
            "low-value-noise-handling",
            "prompt-coverage-gaps",
            "optional-follow-up"
          ]
        },
        "priority": {
          "enum": [
            "high",
            "medium",
            "low"
          ]
        },
        "fixType": {
          "enum": [
            "technical",
            "content",
            "both"
          ]
        },
        "whyItMatters": {
          "type": "string",
          "minLength": 1
        },
        "smallestChangeSet": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "affectedEvidence": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "affectedPages": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "counts": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    }
  }
}
